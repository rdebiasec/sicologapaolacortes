{
  "name": "paola-cortes-site",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:static",
    "build:static": "node scripts/generate-seo.mjs && vite build && node scripts/check-dist.mjs",
    "preview": "vite preview",
    "compat:targets": "browserslist",
    "test:e2e:install": "playwright install",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:compat": "npm run build && npm run test:e2e"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "autoprefixer": "^10.5.4",
    "postcss": "^8.5.20",
    "vite": "^8.0.16"
  }
}
