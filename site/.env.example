# Public base URL for canonical/OG/sitemap (required for production deploys).
# Examples:
# - GitHub Pages project: https://user.github.io/repo
# - GitHub Pages custom domain: https://www.example.com
# - Render static domain: https://your-site.onrender.com
VITE_SITE_URL=

# Optional business/contact values (public in client bundle).
VITE_WHATSAPP_NUMBER=
VITE_CONTACT_EMAIL=
VITE_BUSINESS_HOURS=
VITE_INSTAGRAM_HANDLE=

# Optional GA4 measurement ID (G-XXXXXXXXXX). Leave empty to disable analytics.
VITE_GA4_ID=

# Base path for subdirectory deploys.
# - Project pages: /repo/
# - Root domain: /
VITE_BASE_PATH=/
